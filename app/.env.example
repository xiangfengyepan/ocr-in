# Frontend dev configuration — copy to `app/.env` (gitignored).
# Loaded into the environment by `npm start` (via dotenv-cli) before `ng serve`.

# Dev-server port. Angular's dev server reads PORT.
# If you change it, update the backend's OCR_CORS_ORIGINS (api/.env) to match.
PORT=4200

# Note: the API base URL the app calls is NOT set here — it is a runtime value
# in app/public/config.json ({"apiBase": "http://localhost:8000"}).
