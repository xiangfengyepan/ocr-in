# Backend configuration — copy to `api/.env` and adjust.
# Loaded by pydantic-settings (prefix OCR_). `api/.env` is gitignored.

# Allowed web-app origin(s) for CORS, comma-separated. Must match the URL the
# frontend is served from (Angular dev server defaults to http://localhost:4200).
OCR_CORS_ORIGINS=http://localhost:4200

# Ollama server used for the optional text correction.
OCR_OLLAMA_HOST=http://localhost:11434

# Storage locations (defaults live inside the repo).
# OCR_MODELS_DIR=./models
# OCR_DATASETS_DIR=./datasets
# OCR_COLLECTED_DIR=./datasets/collected

# The web app's API base URL is NOT set here — it is a runtime value in
# app/public/config.json ({"apiBase": "http://localhost:8000"}), so a built/
# deployed frontend can be repointed without a rebuild.
